# Copy this to .streamlit/secrets.toml for local development, or paste the
# same keys into the "Secrets" box in Streamlit Community Cloud's app settings.
# Never commit the real .streamlit/secrets.toml file.

LLM_REVIEW_ENABLED = "false"
LLM_PROVIDER = "none"
ANTHROPIC_API_KEY = ""
ANTHROPIC_MODEL = "claude-sonnet-5"
LLM_SELECTIVE_SECTIONS_ONLY = "true"
