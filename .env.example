# Enable/disable the LLM analysis stage. If false, only rule-based findings are produced.
LLM_REVIEW_ENABLED=false

# LLM provider: "anthropic" | "none"
LLM_PROVIDER=none

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Model to use for review analysis
ANTHROPIC_MODEL=claude-sonnet-5

# If true, only sections flagged by the rule engine (or short/weak) are sent to the LLM.
LLM_SELECTIVE_SECTIONS_ONLY=true

# SQLite database file path (relative to project root)
DATABASE_PATH=./data/fs-review.db
